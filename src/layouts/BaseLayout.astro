---
import BaseHead from '../components/BaseHead.astro';
import Schema from '../components/Schema.astro';

interface Props {
  title: string;
  description?: string;
  /** Override the canonical URL for this page */
  canonical?: string;
  /** Set false to omit the LocalBusiness/FAQPage JSON-LD — e.g. secondary pages that don't own the FAQ content */
  schema?: boolean;
}

const { title, description, canonical, schema = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} canonical={canonical} />
    {schema && <Schema />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Karla:ital,wght@0,400;0,600;0,800;1,400&family=Luckiest+Guy&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    background: #fff6ea;
    font-family: 'Karla', sans-serif;
    color: #2b1a12;
  }
  a {
    color: #d82b27;
    text-decoration: none;
  }
  a:hover {
    color: #a81e1b;
  }
  ::selection {
    background: #ffc20e;
    color: #2b1a12;
  }
  details > summary {
    list-style: none;
    cursor: pointer;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
