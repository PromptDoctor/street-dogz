---
import { BUSINESS } from '../config/business';

const menu = BUSINESS.menu ?? [];
const regularItems = menu.filter((item) => item.price !== 'Ask when you book');
const specialItems = menu.filter((item) => item.price === 'Ask when you book');
---

<section id="menu" class="menu">
  <div class="wrap">
    <div class="heading-row">
      <h2>MENU</h2>
      <p class="subhead">Made for you ★ Affordable ★ Fresh off the truck</p>
    </div>

    <div class="grid">
      {regularItems.map((item) => (
        <div class="item">
          <div class="item-text">
            <div class="item-name">{item.name.toUpperCase()}</div>
            <div class="item-desc">{item.description}</div>
          </div>
          <div class="item-price">{item.price}</div>
        </div>
      ))}
    </div>

    {specialItems.length > 0 && (
      <div class="special-strip">
        <span class="special-label">SPECIAL ORDER ★</span>
        {specialItems.map((item) => (
          <span class="special-item">{item.name}</span>
        ))}
        <a href="#book" class="special-link">Ask when you book →</a>
      </div>
    )}
  </div>
</section>

<style>
  .menu {
    background: #d82b27;
    padding: clamp(48px, 7vw, 90px) clamp(20px, 5vw, 64px);
  }
  .wrap {
    max-width: 1100px;
    margin: 0 auto;
  }
  .heading-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 34px;
  }
  h2 {
    font-family: 'Luckiest Guy', cursive;
    font-size: clamp(44px, 7vw, 76px);
    color: #fff6ea;
    margin: 0;
    line-height: 1;
    text-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
  }
  .subhead {
    color: #ffd9c2;
    font-weight: 600;
    font-size: 17px;
    margin: 0 0 6px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 420px), 1fr));
    gap: 14px;
  }
  .item {
    background: rgba(255, 246, 234, 0.08);
    border: 2px solid rgba(255, 246, 234, 0.25);
    border-radius: 14px;
    padding: 16px 18px;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .item:hover {
    background: rgba(255, 246, 234, 0.16);
    transform: translateY(-2px);
  }
  .item-text {
    flex: 1;
  }
  .item-name {
    font-family: 'Luckiest Guy', cursive;
    font-size: 21px;
    color: #fff6ea;
    letter-spacing: 0.5px;
  }
  .item-desc {
    color: #ffd9c2;
    font-size: 14px;
    font-weight: 600;
    margin-top: 2px;
  }
  .item-price {
    font-family: 'Luckiest Guy', cursive;
    font-size: 22px;
    color: #ffc20e;
  }
  .special-strip {
    margin-top: 30px;
    background: #ffc20e;
    border-radius: 14px;
    padding: 16px 20px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 18px;
    box-shadow: 0 5px 0 rgba(0, 0, 0, 0.2);
  }
  .special-label {
    font-family: 'Luckiest Guy', cursive;
    font-size: 19px;
    color: #d82b27;
    padding-top: 3px;
  }
  .special-item {
    font-weight: 800;
    font-size: 16px;
    color: #2b1a12;
  }
  .special-link {
    margin-left: auto;
    font-weight: 800;
    font-size: 15px;
    color: #d82b27;
    text-decoration: underline;
  }
  .special-link:hover {
    color: #8f1714;
  }
</style>
