---
import BookingForm from './BookingForm';
import { BUSINESS } from '../config/business';
import { toTelHref } from '../utils/phone';

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const telHref = toTelHref(BUSINESS.phone);
---

<section id="book" class="book">
  <div class="wrap">
    <div class="info-col">
      <h2>Book the truck</h2>
      <p class="lede">Tell us about your event and we'll get back to you fast. Or just call — we answer.</p>
      <div class="info-list">
        <a href={telHref} class="info-card">☎ {BUSINESS.phone}</a>
        <a href={`mailto:${BUSINESS.email}`} class="info-card">✉ {BUSINESS.email}</a>
        {BUSINESS.hours.map((entry) => (
          <div class="info-card">🕘 Open {entry.days}, {entry.hours}</div>
        ))}
      </div>
    </div>
    <div class="form-col">
      <BookingForm accessKey={accessKey} client:visible />
    </div>
  </div>
</section>

<style>
  .book {
    background: linear-gradient(160deg, #f7941d 0%, #ffc20e 100%);
    padding: clamp(48px, 7vw, 90px) clamp(20px, 5vw, 64px);
  }
  .wrap {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(28px, 5vw, 56px);
  }
  .info-col {
    flex: 1 1 300px;
    min-width: 280px;
  }
  h2 {
    font-family: 'Luckiest Guy', cursive;
    font-size: clamp(38px, 5.5vw, 60px);
    color: #d82b27;
    line-height: 1;
    margin: 0 0 14px;
    text-shadow: 2px 2px 0 #fff6ea;
  }
  .lede {
    font-weight: 600;
    font-size: 17px;
    line-height: 1.6;
    color: #5a3a12;
    margin: 0 0 24px;
  }
  .info-list {
    display: grid;
    gap: 12px;
  }
  .info-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fff6ea;
    border-radius: 12px;
    padding: 14px 18px;
    color: #2b1a12;
    font-weight: 800;
    font-size: 17px;
    box-shadow: 0 4px 0 rgba(0, 0, 0, 0.15);
  }
  a.info-card:hover {
    transform: translateY(-2px);
  }
  .form-col {
    flex: 1 1 480px;
    min-width: 300px;
    background: #fff6ea;
    border-radius: 20px;
    padding: clamp(20px, 3vw, 32px);
    box-shadow: 0 8px 0 #d82b27, 0 16px 28px rgba(0, 0, 0, 0.15);
  }
</style>

<style is:global>
  .bf-form {
    display: grid;
    gap: 14px;
  }
  .bf-form input[type='text'],
  .bf-form input[type='tel'],
  .bf-form input[type='email'],
  .bf-form input[type='date'],
  .bf-form input[type='time'],
  .bf-form input[type='number'],
  .bf-form textarea {
    border: 2px solid #e8d5c4;
    border-radius: 10px;
    padding: 12px 14px;
    font-family: 'Karla', sans-serif;
    font-size: 15px;
    font-weight: 600;
    background: #ffffff;
    color: #2b1a12;
    width: 100%;
    box-sizing: border-box;
  }
  .bf-form input:focus,
  .bf-form textarea:focus {
    border-color: #d82b27;
    outline: none;
  }
  .bf-form input::placeholder,
  .bf-form textarea::placeholder {
    color: #b0968a;
    opacity: 1;
  }
  .bf-form textarea {
    resize: vertical;
  }
  .bf-section-label {
    font-family: 'Luckiest Guy', cursive;
    font-size: 17px;
    color: #d82b27;
    margin-top: 6px;
  }
  .bf-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .bf-row-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 14px;
  }
  .bf-field-label {
    display: grid;
    gap: 5px;
    font-size: 12px;
    font-weight: 800;
    color: #8a6e5c;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .bf-payer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 18px;
  }
  .bf-payer-label {
    font-size: 12px;
    font-weight: 800;
    color: #8a6e5c;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .bf-radio {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 15px;
    font-weight: 700;
    color: #2b1a12;
    cursor: pointer;
  }
  .bf-radio input {
    accent-color: #d82b27;
    width: 18px;
    height: 18px;
    cursor: pointer;
  }
  .bf-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .bf-item {
    border: 2px solid #e8d5c4;
    background: #ffffff;
    color: #2b1a12;
    border-radius: 999px;
    padding: 8px 14px;
    font-family: 'Karla', sans-serif;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
  }
  .bf-item:hover {
    border-color: #d82b27;
  }
  .bf-item-on {
    border-color: #d82b27;
    background: #d82b27;
    color: #fff6ea;
  }
  .bf-ack {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    color: #5a4438;
    line-height: 1.5;
    cursor: pointer;
  }
  .bf-ack input {
    accent-color: #d82b27;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .bf-submit {
    background: #d82b27;
    color: #fff6ea;
    font-family: 'Luckiest Guy', cursive;
    font-size: 21px;
    padding: 14px 20px 10px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: 0 5px 0 #8f1714;
  }
  .bf-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 7px 0 #8f1714;
  }
  .bf-submit:active:not(:disabled) {
    transform: translateY(1px);
    box-shadow: 0 3px 0 #8f1714;
  }
  .bf-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .bf-fineprint {
    margin: 0;
    font-size: 12.5px;
    font-weight: 600;
    color: #8a6e5c;
    line-height: 1.5;
  }
  .bf-error {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    color: #a81e1b;
  }
  .bf-success {
    display: grid;
    place-items: center;
    text-align: center;
    min-height: 200px;
    font-size: 17px;
    font-weight: 700;
    color: #2b1a12;
  }
</style>
