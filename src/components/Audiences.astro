---
import { BUSINESS } from '../config/business';

const audiences = BUSINESS.audiences ?? [];

// Natural-language join so this stays in sync with the areaServed values
// used in Schema.astro instead of hand-authored copy drifting out of date.
const areas = BUSINESS.areaServed;
const areaText =
  areas.length > 1
    ? `${areas.slice(0, -1).join(', ')} and ${areas[areas.length - 1]}`
    : areas[0];
---

<section id="events" class="audiences">
  <div class="wrap">
    <h2>We roll up anywhere</h2>
    <p class="subhead">Catering across {areaText}</p>
    <div class="grid">
      {audiences.map((aud) => (
        <div class="card">
          <div class="icon">{aud.icon}</div>
          <div class="label">{aud.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .audiences {
    background: #3e9b4f;
    padding: clamp(48px, 7vw, 90px) clamp(20px, 5vw, 64px);
    border-top: 4px solid #2b1a12;
    border-bottom: 4px solid #2b1a12;
  }
  .wrap {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  h2 {
    font-family: 'Luckiest Guy', cursive;
    font-size: clamp(36px, 5.5vw, 60px);
    color: #fff6ea;
    margin: 0 0 8px;
    text-shadow: 3px 3px 0 rgba(0, 0, 0, 0.2);
  }
  .subhead {
    color: #dff3e2;
    font-weight: 700;
    font-size: 17px;
    margin: 0 0 36px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 14px;
  }
  .card {
    background: #fff6ea;
    border-radius: 16px;
    padding: 24px 14px 20px;
    box-shadow: 0 5px 0 rgba(0, 0, 0, 0.25);
  }
  .card:hover {
    transform: translateY(-4px) rotate(-1deg);
  }
  .icon {
    font-size: 38px;
    line-height: 1;
  }
  .label {
    font-family: 'Luckiest Guy', cursive;
    font-size: 19px;
    color: #2b1a12;
    margin-top: 10px;
  }
</style>
