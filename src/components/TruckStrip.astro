---
import { Image } from 'astro:assets';
import truckPhoto from '../assets/images/hero-truck.jpg';
import { BUSINESS } from '../config/business';
---

<section class="truck-strip">
  <div class="wrap">
    <div class="photo-col">
      <Image
        src={truckPhoto}
        alt={`${BUSINESS.name} food truck — full color wrap with hotdog mascots and St. Louis skyline`}
        widths={[460, 920]}
        sizes="(min-width: 700px) 460px, 100vw"
        class="photo"
      />
    </div>
    <div class="text-col">
      <h2>Look for the loudest truck on the block</h2>
      <p>We're the 100% electric hotdog truck covered in mascots, street signs, and St. Louis skyline. If you can see it, you can smell the brats.</p>
      <a href="#book" class="btn">Bring it to your event</a>
    </div>
  </div>
</section>

<style>
  .truck-strip {
    background: #fff6ea;
    padding: clamp(48px, 7vw, 90px) clamp(20px, 5vw, 64px);
  }
  .wrap {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(24px, 4vw, 48px);
  }
  .photo-col {
    flex: 1 1 460px;
    min-width: 300px;
  }
  .photo {
    width: 100%;
    height: auto;
    border-radius: 18px;
    box-shadow: 0 10px 0 #ffc20e, 0 18px 30px rgba(0, 0, 0, 0.15);
    display: block;
  }
  .text-col {
    flex: 1 1 320px;
    min-width: 280px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  h2 {
    font-family: 'Luckiest Guy', cursive;
    font-size: clamp(32px, 4.5vw, 48px);
    color: #d82b27;
    line-height: 1.05;
    margin: 0 0 14px;
  }
  p {
    font-size: 17px;
    line-height: 1.6;
    margin: 0 0 20px;
    font-weight: 600;
    color: #5a4438;
    max-width: 420px;
  }
  .btn {
    background: #7d6bb0;
    color: #fff6ea;
    font-family: 'Luckiest Guy', cursive;
    font-size: 19px;
    padding: 12px 26px 9px;
    border-radius: 12px;
    box-shadow: 0 4px 0 #564880;
    display: inline-block;
  }
  .btn:hover {
    color: #fff6ea;
    transform: translateY(-2px);
    box-shadow: 0 6px 0 #564880;
  }
</style>
