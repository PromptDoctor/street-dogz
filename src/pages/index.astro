---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Menu from '../components/Menu.astro';
import TruckStrip from '../components/TruckStrip.astro';
import Audiences from '../components/Audiences.astro';
import Booking from '../components/Booking.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import { BUSINESS } from '../config/business';
---

<BaseLayout title={BUSINESS.name}>
  <Header />

  <main>
    <Hero />
    <Menu />
    <TruckStrip />
    <Audiences />

    <Booking />

    <FAQ heading="Questions? We got answers." />
  </main>

  <Footer />
</BaseLayout>
