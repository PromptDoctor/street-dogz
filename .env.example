# Web3Forms — get a free access key at https://web3forms.com
# This key is tied to your verified email and is intentionally public — it's safe in
# client-side code. Spam protection comes from the honeypot field in the form, not
# from keeping this key secret.
PUBLIC_WEB3FORMS_KEY=your_key_here

# Web3Forms submission endpoint — copy this value exactly
PUBLIC_WEB3FORMS_URL=https://api.web3forms.com/submit
